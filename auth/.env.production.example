# cdcf-infra/auth — production env template
#
# Copy to .env.production on the VPS only (path:
# /opt/cdcf-auth/auth/.env.production). NEVER commit values.
# The chrooted deploy user is the only account that should read this
# file (mode 0600).

# ─── Host Postgres connection (shared with other VPS services) ───────
#
# Zitadel and OpenFGA both connect to the host's native PostgreSQL via
# the docker-bridge host-gateway. Roles + databases must exist on the
# host BEFORE bringing up the stack — see README.md "Prerequisites" for
# the exact SQL.

ZITADEL_DB_NAME=zitadel
ZITADEL_DB_USER=zitadel
ZITADEL_DB_PASSWORD=

OPENFGA_DB_NAME=openfga
OPENFGA_DB_USER=openfga
OPENFGA_DB_PASSWORD=

# ─── Zitadel ──────────────────────────────────────────────────────────

# Zitadel masterkey — exactly 32 chars. Generate once, NEVER rotate.
# (Loss of the masterkey makes the Postgres dump unrecoverable.)
#   openssl rand -base64 32 | head -c 32
ZITADEL_MASTERKEY=

# Bootstrap admin user (IAM-OWNER) created on first boot.
# Forced password change on first login (set via
# ZITADEL_FIRSTINSTANCE_ORG_HUMAN_PASSWORDCHANGEREQUIRED=true in compose).
#
# IMPORTANT: this password must satisfy Zitadel's *default* password
# complexity policy, which is evaluated during the 03_default_instance
# migration that creates this user. Defaults are:
#   - minimum length 8
#   - at least one uppercase letter
#   - at least one lowercase letter
#   - at least one digit
#   - at least one symbol (this is the one that trips up alphanumeric-only generators)
# Safe generator that guarantees all four classes:
#   echo "$(openssl rand -base64 64 | tr -d '/+=' | head -c 16)Aa1!"
ZITADEL_ADMIN_USER=zitadel-admin
ZITADEL_ADMIN_PASSWORD=

# ─── OpenFGA ──────────────────────────────────────────────────────────

# Preshared key for OpenFGA HTTP API authn. Consumers (LitCal, etc.)
# pass this as a Bearer token in the Authorization header. Rotate by
# appending the new key (comma-separated in OPENFGA_AUTHN_PRESHARED_KEYS)
# and removing the old after consumers have migrated.
#   openssl rand -base64 48
OPENFGA_PRESHARED_KEY=
