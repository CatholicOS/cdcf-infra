# cdcf-infra/auth — production env template
#
# Copy to .env.production on the VPS only. NEVER commit values.
# The chrooted deploy user is the only account that should be able to read
# this file (mode 0600).

# ─── Zitadel ──────────────────────────────────────────────────────────

# Postgres password for the zitadel-db instance. One-time secret.
ZITADEL_DB_PASSWORD=

# Zitadel masterkey — exactly 32 chars. Generate once, NEVER rotate.
#   openssl rand -base64 32 | head -c 32
ZITADEL_MASTERKEY=

# Bootstrap admin user (IAM-OWNER) created on first boot.
# Change password on first login (ZITADEL_FIRSTINSTANCE_ORG_HUMAN_PASSWORDCHANGEREQUIRED=true).
ZITADEL_ADMIN_USER=zitadel-admin
ZITADEL_ADMIN_PASSWORD=

# ─── OpenFGA ──────────────────────────────────────────────────────────

# Postgres password for the openfga-db instance. One-time secret.
OPENFGA_DB_PASSWORD=

# Preshared key for OpenFGA HTTP API authn. Consumers (LitCal, etc.) pass
# this as a Bearer token in the Authorization header. Rotate by appending
# the new key and removing the old after consumers have migrated.
#   openssl rand -base64 48
OPENFGA_PRESHARED_KEY=
